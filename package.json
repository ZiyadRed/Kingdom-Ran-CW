{
  "name": "kingdom-ran-en",
  "version": "0.1.0",
  "description": "Kingdom Ran (Kingdom Ran: Road to Unification) – English Souha Skill Simulator",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "sync:star6": "node scripts/sync_star6.mjs",
    "validate:cw6": "node scripts/validate_cw6.mjs",
    "prebuild": "node scripts/sync_star6.mjs && node scripts/validate_cw6.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  }
}
